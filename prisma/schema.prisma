// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Core Entities ---

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  name                    String?
  firebaseUid             String?   @unique
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   // active subscription ID
  credits                 Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime? // soft delete: set on account deletion, hard deleted after 30 days
  hasCompletedOnboarding  Boolean   @default(false)
  objective               String?
  plan                    String    @default("gratis") // gratis, essencial, profissional, estrategico

  // Relations
  decisions           Decision[]
  plans               Plan[]
  risks               Risk[]
  sessions            Session[]
  documents           Document[]
  ingestionJobs       DocumentIngestionJob[]
  eventLogs           EventLog[]
  strategicDna        StrategicDNA?
  systemHealth        SystemHealth?
  strategicMode       String   @default("equilibrado") // conservador, equilibrado, expansao
  decisionSuggestions DecisionSuggestion[]
  planSuggestions     PlanSuggestion[]
  suggestionFeedbacks SuggestionFeedback[]
  documentAuditLogs   DocumentAuditLog[]
  agentJobs           AgentJob[]
  creditLogs          CreditLog[]
}

model Decision {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("draft") // draft, active, completed, archived
  impact      String   @default("medium") // low, medium, high, critical
  confidence  Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  plans       Plan[]
  documents   Document[]
}

model Plan {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("planning") // planning, active, completed, blocked
  priority    String   @default("medium") // low, medium, high, critical
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  decisionId  String?
  decision    Decision? @relation(fields: [decisionId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tasks       Task[]
  documents   Document[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  status      String   @default("todo") // todo, in_progress, done, blocked
  dueDate     DateTime?
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Risk {
  id          String   @id @default(uuid())
  title       String
  description String?
  severity    String   @default("medium") // low, medium, high, critical
  status      String   @default("active") // active, mitigated, resolved, dismissed
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  documents   Document[]
}

model Document {
  id          String   @id @default(uuid())
  title       String
  type        String   // PDF, DOCX, TXT
  size        Int      @default(0)
  storageUrl  String?
  storagePath String?
  mimeType    String?
  checksum    String?
  status      String   @default("uploaded") // uploaded, processing, processed, error
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  processedAt DateTime?
  isConfidential Boolean @default(false)
  retentionExpiresAt DateTime? // When document should be auto-deleted

  // Relations
  insights            DocumentInsights?
  linkedDecisions     Decision[]
  linkedPlans         Plan[]
  linkedRisks         Risk[]
  decisionSuggestions DecisionSuggestion[]
  planSuggestions     PlanSuggestion[]
  ingestionJobs       DocumentIngestionJob[]
  auditLogs           DocumentAuditLog[]

  @@index([userId, retentionExpiresAt])
  @@index([userId, createdAt])
}

model DocumentInsights {
  id                String   @id @default(uuid())
  documentId        String   @unique
  document          Document @relation(fields: [documentId], references: [id])
  summary           String?
  decisionsJson     String? // JSON
  risksJson         String? // JSON
  opportunitiesJson String? // JSON
  suggestedPlanJson String? // JSON
  confidenceScore   Float    @default(0)
  processingTimeMs  Int      @default(0) // milliseconds from ingestion to completion
  createdAt         DateTime @default(now())
  processedAt       DateTime? // When analysis completed
}

model DecisionSuggestion {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  documentId      String
  document        Document @relation(fields: [documentId], references: [id])
  title           String
  description     String?
  impactScore     Int      @default(0) // 0-100
  riskScore       Int      @default(0) // 0-100
  confidenceScore Int      @default(0) // 0-100
  status          String   @default("pending") // pending, accepted, dismissed
  createdAt       DateTime @default(now())
}

model PlanSuggestion {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  documentId      String
  document        Document @relation(fields: [documentId], references: [id])
  title           String
  objective       String?
  phasesJson      String? // JSON
  tasksJson       String? // JSON
  timelineEstimate String?
  confidenceScore Int      @default(0) // 0-100
  status          String   @default("pending") // pending, accepted, dismissed
  createdAt       DateTime @default(now())
}

model DocumentAuditLog {
  id          String   @id @default(uuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String   // upload, view, share, delete, export, mark_confidential
  reason      String?  // Why action was taken
  metadata    String?  // JSON string with additional details
  ipAddress   String?  // IP address from request
  createdAt   DateTime @default(now())

  @@index([documentId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model SuggestionFeedback {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  suggestionId        String   // ID of the suggestion being fed  back on
  suggestionType      String   // "decision" or "plan"
  action              String   // "accepted" or "dismissed"
  usefulnessScore     Int?     // 1-5 optional rating if provided
  comment             String?  // Optional user comment
  createdAt           DateTime @default(now())
  
  @@index([userId, createdAt])
  @@index([suggestionType, action])
}

model DocumentIngestionJob {
  id          String   @id @default(uuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  status      String   @default("queued") // queued, processing, completed, failed
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  lastError   String?
  payloadJson String?
  nextRetryAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, nextRetryAt])
  @@index([documentId, createdAt])
}

model Session {
  id          String   @id @default(uuid())
  title       String
  type        String   // strategy, review, planning
  status      String   @default("scheduled") // scheduled, active, completed
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Event Engine & Audit ---

model EventLog {
  id          String   @id @default(uuid())
  eventType   String
  entityType  String
  entityId    String?
  metadata    String?  // JSON string
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  // Relations
  explanation ExplanationLog?
}

model ExplanationLog {
  id             String   @id @default(uuid())
  title          String
  whatChanged    String
  whyChanged     String
  impact         String
  recommendation String
  deltas         String?  // JSON string
  relatedEventId String   @unique
  event          EventLog @relation(fields: [relatedEventId], references: [id])
  createdAt      DateTime @default(now())
}

// --- Metrics ---

model StrategicDNA {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id])
  decisionQuality      Int      @default(0)
  riskDiscipline       Int      @default(0)
  executionDiscipline  Int      @default(0)
  focusLeverage        Int      @default(0)
  strategicConsistency Int      @default(0)
  overallScore         Int      @default(0)
  lastUpdated          DateTime @default(now())
}

model SystemHealth {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  activeRisksSeverity Int      @default(0)
  executionStability  Int      @default(0)
  alignment           Int      @default(0)
  momentum            Int      @default(0)
  overallScore        Int      @default(0)
  lastUpdated         DateTime @default(now())
}

model AgentJob {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agentType         String    // "decision" | "clarity" | "leverage"
  status            String    @default("pending") // pending | processing | done | failed
  
  inputPayload      Json      // {documentIds, context, ...}
  outputResult      Json?     // resultado do agente
  errorMessage      String?   // se failed
  
  n8nExecutionId    String?   // para rastreabilidade em n8n
  
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  
  @@index([userId])
  @@index([status])
  @@index([agentType])
}

model CreditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      // positivo = recarga, negativo = consumo
  reason    String   // 'subscription_renewal', 'pack_purchase', 'agent_usage', 'onboarding_bonus', 'plan_change'
  agentType String?  // 'DECISION' | 'CLARITY' | 'LEVERAGE' (quando reason = agent_usage)
  metadata  Json?    // dados extras (priceId, jobId, etc.)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
