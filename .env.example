# ============================================
# Configuração de Ambiente TaskForge
# ============================================

# --------------------------------------------
# Configuração do Banco de Dados
# --------------------------------------------
# SQLite (Desenvolvimento/Local)
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (Produção) - Descomente e configure para produção
# Formatos de exemplo:
# Neon: postgresql://user:pass@host/dbname?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Railway: postgresql://user:pass@host:port/dbname
# DATABASE_URL="postgresql://user:password@localhost:5432/taskforge"

# --------------------------------------------
# Configuração de IA
# --------------------------------------------
# Chave de API do Gemini AI (Necessária para recursos de IA)
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=""

# --------------------------------------------
# Configuração da Aplicação
# --------------------------------------------
# URL da Aplicação (usada para callbacks e geração de links)
# Desenvolvimento
APP_URL="http://localhost:5173"
# Produção - Atualize com a URL do seu deploy
# APP_URL="https://seu-app.com"

# Porta do Servidor
PORT=5000

# Ambiente Node (development|production|test)
NODE_ENV="development"

# --------------------------------------------
# Configuração do Firebase
# --------------------------------------------
# ID do Projeto Firebase
FIREBASE_PROJECT_ID="taskforge-addb3"

# Conta de Serviço Firebase (Somente Produção)
# Caminho para o arquivo JSON da conta de serviço ou string JSON
# FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccountKey.json"
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Configuração Web do Firebase (Frontend)
# Obtenha do Console Firebase > Configurações do Projeto > Seus aplicativos
# VITE_FIREBASE_API_KEY=""
# VITE_FIREBASE_AUTH_DOMAIN="taskforge-addb3.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID="taskforge-addb3"
# VITE_FIREBASE_STORAGE_BUCKET="taskforge-addb3.appspot.com"
# VITE_FIREBASE_MESSAGING_SENDER_ID=""
# VITE_FIREBASE_APP_ID=""

# --------------------------------------------
# Configuração de Segurança
# --------------------------------------------
# Configuração CORS
# Lista de origens permitidas separadas por vírgula
# Desenvolvimento
CORS_ORIGIN="http://localhost:5173,http://localhost:5000"
# Produção - Substitua pelos seus domínios reais
# CORS_ORIGIN="https://seu-app.com,https://www.seu-app.com"

# Segredo de Sessão (Gere com: openssl rand -base64 32)
# SESSION_SECRET=""

# Segredo JWT (se usar autenticação JWT)
# JWT_SECRET=""

# --------------------------------------------
# Flags de Recursos
# --------------------------------------------
# Habilitar/desabilitar recursos
ENABLE_AI_SUGGESTIONS="true"
ENABLE_DOCUMENT_PROCESSING="false"
ENABLE_REALTIME_UPDATES="true"

# --------------------------------------------
# Monitoramento e Logging
# --------------------------------------------
# Nível de Log (error|warn|info|debug)
LOG_LEVEL="info"

# Habilitar logging de requisições
ENABLE_REQUEST_LOGGING="true"

# --------------------------------------------
# Conformidade com Plano Gratuito
# --------------------------------------------
# Certifique-se de que estas configurações estão corretas para hospedagem gratuita
# Firebase: Plano Spark (gratuito)
# Banco de Dados: PostgreSQL gratuito (Neon 10GB, Supabase 500MB, etc.)
# Hospedagem: Plano gratuito Vercel/Netlify

